MATCH (n) DETACH DELETE n;

CREATE INDEX ON :Application(id);
CREATE INDEX ON :ApplicationDap(id);
CREATE INDEX ON :Cluster(id);
CREATE INDEX ON :Contact(id);
CREATE INDEX ON :Dap(id);
CREATE INDEX ON :Host(id);
CREATE INDEX ON :ObsolescenceRecord(id);
CREATE INDEX ON :Subcluster(id);
CREATE INDEX ON :Technology(id);
CREATE VECTOR INDEX application_embedding_index ON :Application(embedding) WITH CONFIG {'dimension': 64, 'capacity': 100, 'metric': 'cos'};
CREATE VECTOR INDEX applicationdap_embedding_index ON :ApplicationDap(embedding) WITH CONFIG {'dimension': 64, 'capacity': 100, 'metric': 'cos'};
CREATE VECTOR INDEX cluster_embedding_index ON :Cluster(embedding) WITH CONFIG {'dimension': 64, 'capacity': 100, 'metric': 'cos'};
CREATE VECTOR INDEX contact_embedding_index ON :Contact(embedding) WITH CONFIG {'dimension': 64, 'capacity': 100, 'metric': 'cos'};
CREATE VECTOR INDEX dap_embedding_index ON :Dap(embedding) WITH CONFIG {'dimension': 64, 'capacity': 100, 'metric': 'cos'};
CREATE VECTOR INDEX host_embedding_index ON :Host(embedding) WITH CONFIG {'dimension': 64, 'capacity': 100, 'metric': 'cos'};
CREATE VECTOR INDEX obsolescencerecord_embedding_index ON :ObsolescenceRecord(embedding) WITH CONFIG {'dimension': 64, 'capacity': 100, 'metric': 'cos'};
CREATE VECTOR INDEX subcluster_embedding_index ON :Subcluster(embedding) WITH CONFIG {'dimension': 64, 'capacity': 100, 'metric': 'cos'};
CREATE VECTOR INDEX technology_embedding_index ON :Technology(embedding) WITH CONFIG {'dimension': 64, 'capacity': 100, 'metric': 'cos'};

